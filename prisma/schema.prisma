generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  provider      String?   @default("credentials")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  jobs          Job[]
}

model Job {
  id          String       @id @default(cuid())
  title       String
  company     String
  location    String?
  salary      String?
  url         String?
  status      String       @default("saved")
  source      String?
  jdSnapshot  String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews  Interview[]

  @@index([userId])
}

model Interview {
  id          String   @id @default(cuid())
  round       Int
  type        String   @default("phone")
  scheduledAt DateTime?
  interviewer String?
  feedback    String?
  result      String   @default("pending")
  meetingUrl  String?
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId])
  @@index([scheduledAt])
}